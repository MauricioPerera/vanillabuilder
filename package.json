{
  "name": "vanillabuilder",
  "version": "0.1.0",
  "description": "A zero-dependency web builder framework in vanilla ES6+ JavaScript",
  "type": "module",
  "main": "dist/vanillabuilder.js",
  "module": "dist/vanillabuilder.mjs",
  "exports": {
    ".": {
      "import": "./dist/vanillabuilder.mjs",
      "require": "./dist/vanillabuilder.js"
    },
    "./css": "./dist/vanillabuilder.css"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c --environment BUILD:production",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "rollup": "^4.9.0",
    "@rollup/plugin-terser": "^0.4.4",
    "vitest": "^1.6.0",
    "jsdom": "^24.0.0"
  },
  "keywords": ["web-builder", "page-builder", "drag-drop", "no-code", "visual-editor", "vanilla-js"],
  "license": "MIT",
  "author": ""
}
